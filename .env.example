# GEMINI_API_KEY: Required for Gemini AI API calls.
# AI Studio automatically injects this at runtime from user secrets.
# Users configure this via the Secrets panel in the AI Studio UI.
GEMINI_API_KEY="MY_GEMINI_API_KEY"

# APP_URL: The URL where this applet is hosted.
# AI Studio automatically injects this at runtime with the Cloud Run service URL.
# Used for self-referential links, OAuth callbacks, and API endpoints.
APP_URL="MY_APP_URL"

# FOOTBALL_DATA_API_KEY: Token de https://api.football-data.org (X-Auth-Token).
# Se usa SOLO server-side: en dev via el proxy de Vite (vite.config.ts) y en
# produccion via nginx (nginx.conf.template), nunca se expone al navegador.
FOOTBALL_DATA_API_KEY="MY_FOOTBALL_DATA_API_KEY"

# VITE_PLAUSIBLE_DOMAIN: dominio registrado en plausible.io para analytics.
# Si se deja vacio, no se carga ningun script de analytics.
VITE_PLAUSIBLE_DOMAIN=""
